{
	"productName": "etcd-compass",
	"version": "1.0.0",
	"identifier": "com.etcd.compass",
	"build": {
		"beforeBuildCommand": "npm run build",
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"fullscreen": false,
				"height": 800,
				"resizable": true,
				"title": "ETCD Compass",
				"width": 1400,
				"minWidth": 1000,
				"minHeight": 600,
				"center": true,
				"decorations": true,
				"transparent": false
			}
		],
		"security": {
			"csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost;"
		},
		"trayIcon": {
			"iconPath": "icons/icon.png",
			"iconAsTemplate": true
		}
	},
	"bundle": {
		"active": true,
		"category": "DeveloperTool",
		"copyright": "Copyright (c) 2026 ETCD Compass Contributors",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"longDescription": "A modern desktop client for ETCD clusters - browse keys, manage leases, watch changes",
		"shortDescription": "ETCD Compass - Desktop Client for ETCD",
		"targets": "all",
		"linux": {
			"deb": {
				"depends": []
			}
		},
		"macOS": {
			"entitlements": null,
			"exceptionDomain": "",
			"frameworks": [],
			"providerShortName": null,
			"signingIdentity": null
		},
		"windows": {
			"certificateThumbprint": null,
			"digestAlgorithm": "sha256",
			"timestampUrl": ""
		},
		"resources": [],
		"externalBin": []
	}
}
