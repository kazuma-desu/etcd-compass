{
	"identifier": "default",
	"description": "Default capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"dialog:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"dialog:allow-ask",
		"dialog:allow-confirm",
		"dialog:allow-message",
		"fs:default",
		"fs:allow-read-text-file",
		"fs:allow-write-text-file",
		"fs:allow-read-dir",
		"fs:allow-mkdir",
		"fs:allow-exists",
		"shell:allow-open",
		"notification:default"
	]
}
